# ── Phone Remote server configuration ────────────────────────────────
# Copy to .env and fill in real values. Never commit .env.

# Port the Node.js server listens on (nginx proxies 443 → this)
PORT=3000

# REQUIRED in production — secret used to sign JWTs.
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# How long login tokens stay valid (jsonwebtoken syntax: 30d, 12h, ...)
TOKEN_TTL=30d

# PostgreSQL connection string (RDS). Leave EMPTY to use local SQLite
# (server/data/phoneremote.db) — fine for development, not for production.
# Format: postgres://USER:PASSWORD@HOST:5432/phoneremote
DATABASE_URL=

# Set to "false" only if your Postgres does NOT use TLS (local docker etc.)
# PG_SSL=false

# Root folder for per-account file storage (default: ~/PhoneRemote)
# FILE_DIR=/srv/phoneremote-files
